[node name="Giratran" parent="YSort" index="2" instance=ExtResource("2_ol6wc")]
position = Vector2(-701, 8)
npc_id = "Giratran"
pre_battle_dialogue = Array[String](["Oh? A visitor? How interesting. I have not had a visitor in a very long time.  Seeing you have the crystal drums I guess you met Rudakohm as well hahaha! Don't take his words too hard, he is bestowed with an impossible task, as am I. I may be a Guardian but mostly I am a mere agent of the Energy Efficiency Program.", "I like your boldness, young one. It's a trait that has not been seen in this static world for a long time. But there is a reason for that. You must have taken days, maybe weeks already from the remaining crystals in the reserves of Kruneainon. And despite its coldness, this world still deserves persistence, for as long as possible. This I must believe."])
post_battle_dialogue = Array[String](["Did you know that residents used to live around these parts? Some of the logs you are reading come from those that used to live here, play here, sing here, paint here. Or whatever its digital equivalent may be.", "There used to be other employees here as well, but they were not efficiënt enough, so I am here working alone.", "Alone…", "Maybe you will be able to find another way, young one."])

