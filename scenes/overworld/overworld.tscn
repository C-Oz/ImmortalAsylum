[node name="Rudakohm" parent="YSort" instance=ExtResource("6_0wbp6")]
position = Vector2(-276, 249)
npc_id = "Rudakohm"
pre_battle_dialogue = Array[String](["Stop right there, foolish avatar. Don't think I didn't hear you scurrying about my domain like some filthy virus.", "If you are here, that must mean you have  already ignored every single possible warning you received. You know how many man hours it will take to clean up your mess?", "You deserve no mercy, you dissident. You are an immediate threat to civilian order and the Energy Efficiency Program. I will destroy you where you stand."])
post_battle_dialogue = Array[String](["My old age made me rusty on the drums, which I suppose you will take from me as well.", "You will make Kruneainon a graveyard like all others.", "Your crusade is one of ignorant destruction and death. At least my evil is a necessary one."])

